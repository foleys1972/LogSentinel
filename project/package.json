{
  "name": "logsentinel-enterprise",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && node server.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "electron-builder --win",
    "electron:build:web": "electron-builder --win -c electron-builder-web.json",
    "watchdog": "node watchdog.cjs",
    "watchdog:exe": "node watchdog.cjs",
    "service:start": "node watchdog-service.cjs start",
    "service:stop": "node watchdog-service.cjs stop",
    "service:restart": "node watchdog-service.cjs restart",
    "service:status": "node watchdog-service.cjs status",
    "service:start:exe": "node watchdog-service.cjs start",
    "service:stop:exe": "node watchdog-service.cjs stop",
    "service:restart:exe": "node watchdog-service.cjs restart",
    "watchdog:build": "npx pkg watchdog-service.cjs --targets node18-win-x64 --output dist-watchdog/LogSentinel-Watchdog.exe && node scripts/create-watchdog-bat.cjs",
    "watchdog:ui": "electron watchdog-ui/watchdog-electron-main.cjs",
    "watchdog:ui:build": "electron-builder --win -c electron-builder-watchdog.json"
  },
  "build": {
    "appId": "com.logsentinel.enterprise",
    "productName": "LogSentinel Enterprise",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "chokidar": "^3.5.3",
    "clsx": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^3.0.0",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "isolation-forest": "^0.0.9",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "net-snmp": "^3.26.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "pkg": "^5.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
